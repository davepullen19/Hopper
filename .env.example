# ----------------------------------------------------------------------------
# LOCAL DEVELOPMENT
# No connection pooler locally, so DATABASE_URL and DIRECT_URL are identical.
# ----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hopper?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/hopper?schema=public"

# Session signing secret. Generate a unique one per environment:
#   openssl rand -base64 32
AUTH_SECRET="change-me-generate-with-openssl-rand-base64-32"

# ----------------------------------------------------------------------------
# PRODUCTION (Vercel + Neon)
# Also set AUTH_SECRET in Vercel (a fresh `openssl rand -base64 32`).
# Neon gives you TWO connection strings:
#   DATABASE_URL -> the POOLED string (host contains "-pooler"). Used at runtime
#                   by serverless functions to avoid exhausting DB connections.
#   DIRECT_URL   -> the DIRECT (non-pooled) string. Used for `prisma migrate` /
#                   `prisma db push`.
# Example shape (replace with your real Neon values):
#   DATABASE_URL="postgresql://USER:PASS@ep-xxxx-pooler.eu-west-2.aws.neon.tech/hopper?sslmode=require"
#   DIRECT_URL="postgresql://USER:PASS@ep-xxxx.eu-west-2.aws.neon.tech/hopper?sslmode=require"
# ----------------------------------------------------------------------------
